# Eko Telehealth — backend API environment
# Copy to .env and fill in real values as each account comes online.
# The server BOOTS even with blanks: any route whose service is unconfigured
# returns a clear 503 instead of crashing, so you can deploy first and wire
# services in one at a time. Hit GET /health to see what's live.

# ── Core ────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
# Comma-separated origins allowed by CORS. Include the admin site (Vercel)
# and, for local dev, the Expo/Next dev servers. Leave blank to allow all.
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
# Deep link / URL the payment provider redirects to after checkout.
PAYMENT_REDIRECT_URL=ekotelehealth://payment-complete

# ── Auth (JWT) ──────────────────────────────────────────
# Generate long random strings, e.g. `openssl rand -hex 32`.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# ── Supabase (Postgres datastore) ───────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string (URI).
# Use the "Session pooler" (port 5432) connection for a long-running server.
DATABASE_URL=

# ── Stream (video/audio calls + chat) ───────────────────
# getstream.io → your app → API key + secret. Secret is SERVER-ONLY.
# The API key is public — also expose it to the app as EXPO_PUBLIC_STREAM_API_KEY.
# Also set your Stream app's webhook URL to <api-url>/webhooks/stream so chat
# transcripts persist server-side (verified with STREAM_API_SECRET — no new var).
STREAM_API_KEY=
STREAM_API_SECRET=
STREAM_TOKEN_TTL=3600
# Stream Video call type used for visit rooms.
STREAM_CALL_TYPE=default

# ── Payments: Flutterwave (NGN) ─────────────────────────
# flutterwave.com → Settings → API Keys. Use TEST keys first.
FLUTTERWAVE_SECRET_KEY=
# Dashboard → Settings → Webhooks → "Secret hash" (compared to verif-hash header).
FLUTTERWAVE_WEBHOOK_HASH=

# ── Payments: PayPal (diaspora / USD) ───────────────────
# developer.paypal.com → Apps & Credentials → REST app.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_ENV=sandbox
# Register a webhook on your REST app (URL: <api-url>/webhooks/paypal, events:
# CHECKOUT.ORDER.APPROVED, PAYMENT.CAPTURE.COMPLETED, PAYMENT.CAPTURE.DENIED)
# and paste the Webhook ID PayPal issues — used to verify event signatures.
PAYPAL_WEBHOOK_ID=
# PayPal can't settle NGN. It charges PAYPAL_CURRENCY instead, converting the
# NGN fee at PAYPAL_NGN_RATE (NGN per 1 unit of PAYPAL_CURRENCY). Keep current.
PAYPAL_CURRENCY=USD
PAYPAL_NGN_RATE=1600

# ── Email: Resend ───────────────────────────────────────
# resend.com → API Keys. Verify your sending domain for production.
RESEND_API_KEY=
EMAIL_FROM=Eko Telehealth <no-reply@ekotelehealth.com>

# ── SMS / OTP: Termii ───────────────────────────────────
# termii.com → dashboard → API key. Cheapest for Nigerian OTPs. Leave blank to
# run without SMS (codes are logged instead). Register a Sender ID for prod.
TERMII_API_KEY=
TERMII_SENDER_ID=Eko Health
# generic = cheapest; dnd = delivers to Do-Not-Disturb numbers (pricier); whatsapp
TERMII_CHANNEL=generic
# Local numbers typed as 0803… get this country code prefixed (Nigeria = 234).
SMS_DEFAULT_COUNTRY_CODE=234

# ── Object storage: Cloudflare R2 ───────────────────────
# Cloudflare → R2 → Manage R2 API Tokens → create S3-compatible credentials.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=eko-telehealth
# Public base URL if the bucket is served via a custom domain or r2.dev.
R2_PUBLIC_BASE_URL=
